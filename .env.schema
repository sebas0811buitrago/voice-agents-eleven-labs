# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
# 
# @defaultRequired=infer @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# @plugin(@varlock/bitwarden-plugin@2.0.0)
# @initBwp(sessionTtl="1h", cacheTtl="5m")
# ----------


# ---
# @sensitive @required
XI_API_KEY=bwp("elevenlabsapi", field=password)


# --- ElevenLabs Conversational AI agent (not secret) ---
# @required @sensitive=false
ELEVENLABS_AGENT_ID=

# The phone-number id ElevenLabs created when you imported your Twilio number
# @required @sensitive=false
ELEVENLABS_AGENT_PHONE_NUMBER_ID=

# --- Post-call webhook signing secret (from ElevenLabs webhook settings) ---
# @sensitive @required
ELEVENLABS_WEBHOOK_SECRET=


